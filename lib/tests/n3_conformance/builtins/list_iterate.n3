@prefix : <http://example.org/> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .

:cart :items ( :milk :bread ) .

{ ?cart :items ?list . ?list list:iterate ?pair . ?pair list:first ?idx . ?pair list:rest ?restList . ?restList list:first ?item } => { ?cart :entryIndex ?idx . ?cart :entryItem ?item }.
